# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend CORS Validation
FRONTEND_URL=https://your-production-domain.com

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Webhook Secrets (For Social Media Integrations)
META_VERIFY_TOKEN=your_secure_meta_verify_token
META_APP_SECRET=your_meta_app_secret
LINKEDIN_WEBHOOK_SECRET=your_linkedin_secret

# Admin Contact
ADMIN_PHONE=919876543210

# Security Settings
JWT_SECRET=your_super_secret_jwt_key_for_custom_tokens
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
